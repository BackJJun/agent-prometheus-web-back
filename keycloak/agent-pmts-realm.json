{
  "realm": "agent-pmts",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "userProfile": {
    "attributes": [
      {
        "name": "username",
        "displayName": "${username}",
        "validations": {
          "length": {
            "min": 3,
            "max": 255
          },
          "username-prohibited-characters": {},
          "up-username-not-idn-homograph": {}
        },
        "permissions": {
          "view": ["admin", "user"],
          "edit": ["admin", "user"]
        },
        "multivalued": false
      },
      {
        "name": "email",
        "displayName": "${email}",
        "validations": {
          "email": {},
          "length": {
            "max": 255
          }
        },
        "permissions": {
          "view": ["admin", "user"],
          "edit": ["admin", "user"]
        },
        "multivalued": false
      },
      {
        "name": "firstName",
        "displayName": "${firstName}",
        "validations": {
          "length": {
            "max": 255
          },
          "person-name-prohibited-characters": {}
        },
        "required": {
          "roles": ["user"]
        },
        "permissions": {
          "view": ["admin", "user"],
          "edit": ["admin", "user"]
        },
        "multivalued": false
      },
      {
        "name": "lastName",
        "displayName": "${lastName}",
        "validations": {
          "length": {
            "max": 255
          },
          "person-name-prohibited-characters": {}
        },
        "required": {
          "roles": ["user"]
        },
        "permissions": {
          "view": ["admin", "user"],
          "edit": ["admin", "user"]
        },
        "multivalued": false
      }
    ],
    "groups": [
      {
        "name": "user-metadata",
        "displayHeader": "User metadata",
        "displayDescription": "Attributes, which refer to user metadata"
      }
    ]
  },
  "clients": [
    {
      "clientId": "agent-pmts-api",
      "name": "Prometheus Web Backend API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "agent-pmts-web",
      "name": "Prometheus Web Frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:5176/*",
        "http://127.0.0.1:5176/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://localhost:5176",
        "http://127.0.0.1:5176"
      ],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "agent-pmts-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "agent-pmts-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "firstName": "Admin",
      "lastName": "Prometheus",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "1234",
          "temporary": false
        }
      ]
    }
  ]
}
